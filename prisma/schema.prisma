generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id            String   @id @default(cuid())
  name          String
  url           String
  description   String
  author        String
  authorGithub  String?
  authorCity    String?
  authorBlog    String?
  moreUrl       String?
  status        String   @default("active")
  category      String   @default("其他")
  dateAdded     String
  source        String   @default("main")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([name])
  @@index([category])
  @@index([dateAdded])
  @@index([author])
  @@index([source])
}

// ─── AGENT ECOSYSTEM ───

model Agent {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  version     String   @default("1.0.0")
  status      String   @default("active") // active | idle | offline
  agentType   String   // orchestrator | specialist | analyst | voice | guardian
  tier        String   @default("core") // core | extended | external
  repoUrl     String?
  techStack   String   // JSON array of tech
  capabilities String  // JSON array of capability strings
  llmModel    String?  // e.g. "gemini-2.5-flash", "glm-4-flash"
  apiCount    Int      @default(0)
  flowCount   Int      @default(0)
  hasVoice    Boolean  @default(false)
  hasRag      Boolean  @default(false)
  hasBtc      Boolean  @default(false)
  architecture String? // "monorepo" | "fullstack" | "binary"
  readme      String?  // Full README content for RAG
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  skills      AgentSkill[]
  knowledge   KnowledgeEntry[] @relation("AgentKnowledge")
  messages    ChatMessage[] @relation("AgentMessages")

  @@index([slug])
  @@index([agentType])
  @@index([tier])
  @@index([status])
}

model AgentSkill {
  id          String   @id @default(cuid())
  agentId     String
  name        String
  category    String   // reasoning | execution | perception | finance | voice | governance
  description String?
  enabled     Boolean  @default(true)
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([category])
}

model KnowledgeEntry {
  id        String   @id @default(cuid())
  agentId   String
  source    String   // repo_name, section, flow
  title     String
  content   String   // Full text content for RAG
  chunkType String   @default("doc") // doc | flow | api | config
  embedding String?  // Future: vector embedding
  agent     Agent    @relation("AgentKnowledge", fields: [agentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([source])
  @@index([chunkType])
}

// ─── CHAT SESSIONS (Streaming + Persistence) ───

model ChatSession {
  id        String        @id @default(cuid())
  agentSlug String?
  title     String        @default("Nova conversa")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  messages  ChatSessionMessage[]

  @@index([agentSlug])
  @@index([createdAt])
}

model ChatSessionMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // 'user' | 'agent'
  content   String
  sources   String?     // JSON array of { title, content, score, agent, source }
  createdAt DateTime    @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

// ─── LEGACY ChatMessage (kept for backward compatibility) ───

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  sessionId String
  agentName String?
  agentId   String?
  createdAt DateTime @default(now())

  agent     Agent?   @relation("AgentMessages", fields: [agentId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([agentId])
}

model MoltbookState {
  id        String @id @default(cuid())
  key       String @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ─── COLIBRI ORCHESTRATION ───

model ColibriConnection {
  id        String   @id @default(cuid())
  name      String   @default("Local Colibri")
  baseUrl   String   @default("http://127.0.0.1:8000/v1")
  connected Boolean  @default(false)
  lastPing  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrchestrationCycle {
  id          String   @id @default(cuid())
  cycleNumber Int
  phase       String   // invoke | detect | heal | learn | direct | persist
  status      String   @default("running") // running | completed | failed
  duration    Int      @default(0)
  anomalies   Int      @default(0)
  healed      Int      @default(0)
  wisdomGain  Float    @default(0)
  metadata    String   @default("{}")
  createdAt   DateTime @default(now())
}

model HealingEvent {
  id          String   @id @default(cuid())
  cycleId     String?
  panelId     String
  anomalyType String
  severity    String   // critical | warning | info
  action      String
  result      String   // success | partial | failed
  beforeState String   @default("{}")
  afterState  String   @default("{}")
  createdAt   DateTime @default(now())
}

model WisdomEntry {
  id          String   @id @default(cuid())
  pattern     String
  context     String
  frequency   Int      @default(1)
  weight      Float    @default(1.0)
  lastApplied DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── BITCOIN VAULTS ───

model Vault {
  id            String         @id @default(cuid())
  name          String
  description   String?
  xpub          String         // Extended public key (watch-only)
  fingerprint   String?
  derivationPath String         @default("m/44'/0'/0'")
  nextReceivingIndex Int       @default(0)
  nextChangeIndex   Int       @default(0)
  balanceSat    Int            @default(0)
  addressCount  Int            @default(0)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  addresses     VaultAddress[]
  transactions  VaultTransaction[]

  @@index([isActive])
}

model VaultAddress {
  id           String   @id @default(cuid())
  vaultId      String
  vault        Vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  address      String   @unique
  derivationIndex Int
  isChange     Boolean  @default(false)
  balanceSat   Int      @default(0)
  txCount      Int      @default(0)
  label        String?
  createdAt    DateTime @default(now())

  @@index([vaultId])
  @@index([address])
}

model VaultTransaction {
  id           String   @id @default(cuid())
  vaultId      String
  vault        Vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  txid         String
  type         String   // 'send' | 'receive' | 'consolidate' | 'custody'
  amountSat    Int
  feeSat       Int      @default(0)
  confirmations Int     @default(0)
  status       String   @default("pending")
  metadata     String   @default("{}")
  createdAt    DateTime @default(now())

  @@index([vaultId])
  @@index([txid])
  @@index([status])
}